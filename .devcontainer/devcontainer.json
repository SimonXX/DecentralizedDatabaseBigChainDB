{
    "name": "BigchainDB Demo",
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    "features": {
        "ghcr.io/devcontainers/features/docker-in-docker:2": {}
    },
    "postStartCommand": "bash scripts/start.sh",
    "forwardPorts": [8080, 9984, 9986, 9988, 9990, 26657, 26658, 26659, 26660],
    "portsAttributes": {
        "8080": {
            "label": "React Dashboard",
            "onAutoForward": "openBrowser"
        },
        "9984": { "label": "Coordinator1 API" },
        "9986": { "label": "Member2 API" },
        "9988": { "label": "Member3 API" },
        "9990": { "label": "Member4 API" }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-azuretools.vscode-docker",
                "redhat.vscode-yaml"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/usr/local/bin/python"
            }
        }
    }
}
